<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>عبد الله أبو ناقوس | تصميم وتطوير المواقع - وكالة رقمية احترافية</title>
<meta name="description" content="وكالة عبد الله أبو ناقوس للحلول الرقمية المتكاملة: تصميم مواقع، متاجر إلكترونية، تطبيقات، تحسين SEO، هوية بصرية">
<meta name="author" content="عبد الله أبو ناقوس">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary: #ff6b35;
    --primary-light: #ff8c5a;
    --primary-dark: #e55a2b;
    --secondary: #8b5cf6;
    --secondary-light: #a78bfa;
    --secondary-dark: #7c3aed;
    --dark-bg: #0a0a0f;
    --darker-bg: #050508;
    --card-bg: rgba(20, 20, 30, 0.95);
    --glass-bg: rgba(255,255,255,0.03);
    --light-text: #ffffff;
    --gray-text: #b0b0c0;
    --success: #10b981;
}

body {
    background: var(--dark-bg);
    color: var(--light-text);
    font-family: 'Cairo', sans-serif;
    line-height: 1.6;
    scroll-behavior: smooth;
    overflow-x: hidden;
}

/* animated gradient background */
body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 30%, rgba(139,92,246,0.1), transparent 60%),
                radial-gradient(circle at 80% 70%, rgba(255,107,53,0.08), transparent 70%),
                repeating-linear-gradient(45deg, rgba(255,255,255,0.01) 0px, rgba(255,255,255,0.01) 2px, transparent 2px, transparent 8px);
    pointer-events: none;
    z-index: -1;
}

/* scroll reveal animation */
.reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s ease;
}
.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: #1a1a24; }
::-webkit-scrollbar-thumb { background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 10px; }

/* navbar glass */
.navbar {
    background: rgba(5, 5, 8, 0.9);
    backdrop-filter: blur(20px);
    padding: 12px 6%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}

.logo {
    display: flex;
    align-items: center;
    gap: 15px;
    text-decoration: none;
}

.logo-icon {
    width: 55px;
    height: 55px;
    background: linear-gradient(145deg, var(--primary), var(--secondary));
    border-radius: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 900;
    color: white;
    box-shadow: 0 0 20px rgba(255,107,53,0.4);
    animation: pulseGlow 2s infinite;
}

@keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 5px rgba(255,107,53,0.3); }
    50% { box-shadow: 0 0 25px rgba(255,107,53,0.7); }
}

.logo-icon:hover { animation: shake 0.5s ease; }
@keyframes shake {
    0%,100% { transform: rotate(0deg); }
    25% { transform: rotate(5deg); }
    75% { transform: rotate(-5deg); }
}

.logo-text .name {
    font-size: 24px;
    font-weight: 900;
    background: linear-gradient(135deg, #fff, var(--primary), var(--secondary), #fff);
    background-size: 300% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientShift 3s linear infinite;
}
@keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.logo-text .title {
    font-size: 12px;
    color: var(--gray-text);
}

.social-links a {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 5px;
    text-decoration: none;
    transition: all 0.3s;
    background: rgba(255,255,255,0.05);
}
.social-links a:hover { transform: translateY(-5px) rotate(360deg); transition: 0.4s; }
.facebook { background: #1877F2; color: white; }
.instagram { background: linear-gradient(45deg, #f09433, #d62976, #962fbf); color: white; }
.whatsapp { background: #25D366; color: white; }

/* hero section with particles effect */
.hero {
    padding: 100px 6% 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.hero h1 {
    font-size: 68px;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 25px;
    animation: fadeInUp 0.8s ease;
}

.hero h1 span {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
    position: relative;
}

.hero h1 span::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    transform: scaleX(0);
    animation: expandLine 0.8s ease 0.5s forwards;
}
@keyframes expandLine {
    to { transform: scaleX(1); }
}

.hero p {
    font-size: 1.3rem;
    color: var(--gray-text);
    max-width: 700px;
    margin: 0 auto;
    animation: fadeInUp 0.8s ease 0.2s both;
}

/* hero avatar */
.hero-avatar {
    width: 140px;
    height: 140px;
    margin: 30px auto 20px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 70px;
    color: white;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 0 5px rgba(255,107,53,0.3);
    animation: float 3s ease-in-out infinite;
}
@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
}

/* stats */
.stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    flex-wrap: wrap;
    margin-top: 50px;
    animation: fadeInUp 0.8s ease 0.4s both;
}
.stat-item { text-align: center; }
.stat-number {
    font-size: 48px;
    font-weight: 900;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}
.stat-label { font-size: 14px; color: var(--gray-text); }

/* section title */
.section-title {
    text-align: center;
    font-size: 42px;
    font-weight: 800;
    margin: 80px 0 50px;
    position: relative;
}
.section-title span {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}
.section-title::after {
    content: '';
    width: 100px;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    display: block;
    margin: 15px auto 0;
    border-radius: 4px;
}

/* services grid */
.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 35px;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 6%;
}

.service-card {
    background: var(--card-bg);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 32px;
    padding: 45px 25px;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    backdrop-filter: blur(4px);
    position: relative;
    overflow: hidden;
}
.service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    transform: scaleX(0);
    transition: transform 0.4s;
}
.service-card:hover::before { transform: scaleX(1); }
.service-card:hover {
    transform: translateY(-12px);
    border-color: rgba(255,107,53,0.4);
    box-shadow: 0 25px 45px -12px rgba(0,0,0,0.5);
}
.service-icon {
    width: 85px;
    height: 85px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
    font-size: 38px;
    transition: 0.3s;
}
.service-card:hover .service-icon { transform: scale(1.1) rotate(5deg); }
.service-card h3 { font-size: 26px; margin-bottom: 12px; }
.service-card p { color: var(--gray-text); }

/* portfolio with images */
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 6%;
}
.portfolio-item {
    background: var(--card-bg);
    border-radius: 28px;
    overflow: hidden;
    transition: all 0.4s;
    border: 1px solid rgba(255,255,255,0.08);
}
.portfolio-item:hover { transform: translateY(-10px) scale(1.02); box-shadow: 0 30px 50px -20px black; }
.portfolio-img {
    height: 250px;
    background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
    background-size: 200% 200%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 70px;
    color: var(--primary);
    animation: bgShift 3s ease infinite;
}
@keyframes bgShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}
.portfolio-info { padding: 25px; }
.portfolio-info h4 { font-size: 22px; margin-bottom: 8px; }
.portfolio-info p { color: var(--gray-text); }

/* contact form */
.contact-wrapper {
    max-width: 800px;
    margin: 50px auto 80px;
    padding: 0 6%;
}
.contact-box {
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 48px;
    padding: 55px 45px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.4);
}
.contact-box h2 { text-align: center; margin-bottom: 35px; font-size: 36px; }
.input-group { margin-bottom: 22px; }
.input-group input, .input-group textarea, .input-group select {
    width: 100%;
    padding: 16px 22px;
    background: rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 35px;
    font-size: 1rem;
    transition: 0.3s;
}
.input-group input:focus, .input-group textarea:focus, .input-group select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(255,107,53,0.2);
}
.btn {
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    padding: 16px;
    border: none;
    border-radius: 40px;
    width: 100%;
    font-weight: 700;
    font-size: 1.1rem;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}
.btn:hover { transform: scale(0.98); box-shadow: 0 0 20px rgba(255,107,53,0.5); }

/* testimonials */
.testimonials {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 6%;
}
.testimonial-card {
    background: var(--card-bg);
    border-radius: 32px;
    padding: 35px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.08);
}
.testimonial-text { font-size: 18px; margin-bottom: 20px; color: var(--gray-text); }
.testimonial-author { font-weight: 800; color: var(--primary); font-size: 18px; }

/* floating buttons */
.floating-buttons {
    position: fixed;
    bottom: 25px;
    right: 25px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 99999;
}
.floating-btn {
    width: 60px;
    height: 60px;
    border-radius: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.3s;
    box-shadow: 0 5px 20px rgba(0,0,0,0.3);
}
.floating-btn:hover { transform: scale(1.1); }
.messenger-btn { background: linear-gradient(135deg, var(--primary), var(--secondary)); }
.whatsapp-float { background: #25D366; }
.floating-btn i { font-size: 28px; color: white; }

#toast {
    position: fixed;
    bottom: 110px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--success);
    color: white;
    padding: 14px 32px;
    border-radius: 60px;
    display: none;
    z-index: 100001;
    font-weight: 600;
}

/* admin panel */
.admin-panel {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #0c0c14;
    backdrop-filter: blur(24px);
    padding: 32px;
    border-radius: 40px;
    z-index: 1000001;
    width: 90%;
    max-width: 560px;
    border: 1px solid var(--primary);
}
#overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    backdrop-filter: blur(8px);
    z-index: 1000000;
}
.order-item {
    background: rgba(255,255,255,0.05);
    padding: 18px;
    border-radius: 24px;
    margin-bottom: 16px;
    border-right: 4px solid var(--primary);
}

.footer {
    background: var(--darker-bg);
    padding: 50px 20px 30px;
    text-align: center;
    margin-top: 60px;
    border-top: 1px solid rgba(255,255,255,0.05);
}

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
}

@media(max-width: 768px) {
    .hero h1 { font-size: 36px; }
    .hero p { font-size: 1rem; }
    .section-title { font-size: 32px; }
    .contact-box { padding: 35px 25px; }
    .hero-avatar { width: 100px; height: 100px; font-size: 50px; }
}
</style>
</head>
<body>

<div id="toast">✅ تم إرسال طلبك بنجاح! سنتواصل معك قريباً</div>
<div id="overlay" style="display:none;" onclick="closeAdmin()"></div>

<nav class="navbar">
    <a href="#" class="logo">
        <div class="logo-icon">🇵🇸</div>
        <div class="logo-text">
            <div class="name">عبد الله أبو ناقوس</div>
            <div class="title">مطور ويب محترف | Web Developer</div>
        </div>
    </a>
    <div class="social-links">
        <a href="https://www.facebook.com/share/1P4pMKiWTu/" target="_blank" class="facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="https://www.instagram.com/bdllh.nqws" target="_blank" class="instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://wa.me/0779418419" target="_blank" class="whatsapp"><i class="fab fa-whatsapp"></i></a>
    </div>
</nav>

<div class="floating-buttons">
    <div class="floating-btn whatsapp-float" id="whatsappFloat"><i class="fab fa-whatsapp"></i></div>
    <div class="floating-btn messenger-btn" id="secretBtn"><i class="fas fa-crown"></i></div>
</div>

<section class="hero">
    <div class="hero-avatar">👨‍💻</div>
    <h1>عبد الله <span>أبو ناقوس</span><br>نصنع <span>المواقع</span> التي تبني علامتك</h1>
    <p>مطور ويب محترف | خبرة 5+ سنوات | أكثر من 150 مشروع ناجح</p>
    <div class="stats">
        <div class="stat-item"><div class="stat-number">150+</div><div class="stat-label">مشروع منجز</div></div>
        <div class="stat-item"><div class="stat-number">98%</div><div class="stat-label">رضا العملاء</div></div>
        <div class="stat-item"><div class="stat-number">24/7</div><div class="stat-label">دعم فني</div></div>
    </div>
</section>

<h2 class="section-title">خدماتي <span>الاحترافية</span></h2>
<div class="services-grid">
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-laptop-code"></i></div><h3>تصميم مواقع</h3><p>مواقع حديثة متجاوبة عالية الأداء وتجربة مستخدم مميزة</p></div>
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-cart-shopping"></i></div><h3>متاجر إلكترونية</h3><p>متاجر متكاملة بأنظمة دفع آمنة وإدارة منتجات</p></div>
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-chart-line"></i></div><h3>تحسين SEO</h3><p>ظهور موقعك في الصفحات الأولى وجلب زوار حقيقيين</p></div>
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-paint-brush"></i></div><h3>هوية بصرية</h3><p>شعارات وتصاميم احترافية لعلامتك التجارية</p></div>
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-mobile-alt"></i></div><h3>تطبيقات جوال</h3><p>تطبيقات اندرويد و iOS بجودة عالية</p></div>
    <div class="service-card reveal"><div class="service-icon"><i class="fas fa-cloud-upload-alt"></i></div><h3>استضافة ودعم</h3><p>استضافة سريعة ودعم فني مستمر 24/7</p></div>
</div>

<h2 class="section-title">أحدث <span>أعمالي</span></h2>
<div class="portfolio-grid">
    <div class="portfolio-item reveal"><div class="portfolio-img"><i class="fas fa-store"></i></div><div class="portfolio-info"><h4>متجر الكتروني</h4><p>متجر أزياء متكامل مع نظام دفع إلكتروني</p></div></div>
    <div class="portfolio-item reveal"><div class="portfolio-img"><i class="fas fa-building"></i></div><div class="portfolio-info"><h4>موقع شركة</h4><p>موقع مؤسسة بخدمات احترافية وهوية قوية</p></div></div>
    <div class="portfolio-item reveal"><div class="portfolio-img"><i class="fas fa-graduation-cap"></i></div><div class="portfolio-info"><h4>منصة تعليمية</h4><p>منصة اونلاين مع نظام ادارة متكامل</p></div></div>
</div>

<h2 class="section-title">ماذا يقول <span>عملائي</span></h2>
<div class="testimonials">
    <div class="testimonial-card reveal">
        <div class="testimonial-text">"تعامل احترافي، تصميم جذاب، وتسليم في الوقت المحدد. أنصح بالتعامل مع عبد الله"</div>
        <div class="testimonial-author">- أحمد السيد</div>
    </div>
</div>

<div class="contact-wrapper">
    <div class="contact-box reveal">
        <h2>📋 اطلب خدمتك الآن</h2>
        <div class="input-group"><input type="text" id="userName" placeholder="الاسم الكامل"></div>
        <div class="input-group"><input type="tel" id="userPhone" placeholder="رقم الجوال"></div>
        <div class="input-group">
            <select id="serviceSelect">
                <option value="">-- اختر الخدمة --</option>
                <option value="موقع تعريفي">موقع تعريفي احترافي</option>
                <option value="متجر إلكتروني">متجر إلكتروني متكامل</option>
                <option value="تحسين SEO">تحسين SEO</option>
                <option value="هوية بصرية">هوية بصرية وشعار</option>
                <option value="تطبيق جوال">تطبيق جوال</option>
            </select>
        </div>
        <div class="input-group"><textarea id="orderMsg" rows="3" placeholder="تفاصيل إضافية عن مشروعك"></textarea></div>
        <button class="btn" onclick="sendOrder()">إرسال الطلب <i class="fas fa-paper-plane"></i></button>
    </div>
</div>

<div class="admin-panel" id="adminPanel" style="display:none;">
    <h2 style="text-align:center; margin-bottom:20px;">🔐 لوحة المدير</h2>
    <div id="loginBox">
        <input type="password" id="adminPass" placeholder="كلمة السر" style="width:100%;padding:14px;margin-bottom:20px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:24px;color:white;">
        <button class="btn" onclick="checkLogin()">تسجيل الدخول</button>
    </div>
    <div id="adminContent" style="display:none;">
        <div id="ordersContainer" style="max-height:380px;overflow-y:auto;margin-bottom:20px;"></div>
        <button class="btn" onclick="closeAdmin()" style="background:#2c2c36;">إغلاق</button>
    </div>
</div>

<footer class="footer">
    <p>جميع الحقوق محفوظة © 2025</p>
    <p style="margin-top:12px;background:linear-gradient(135deg,#ff6b35,#8b5cf6);-webkit-background-clip:text;background-clip:text;color:transparent;font-weight:800;">تصميم وتطوير: عبد الله أبو ناقوس | محلل ومطور ويب محترف ✨</p>
</footer>

<script>
// scroll reveal
const reveals = document.querySelectorAll('.reveal');
function revealScroll() {
    reveals.forEach(el => {
        const windowHeight = window.innerHeight;
        const revealTop = el.getBoundingClientRect().top;
        const revealPoint = 150;
        if (revealTop < windowHeight - revealPoint) el.classList.add('active');
    });
}
window.addEventListener('scroll', revealScroll);
revealScroll();

// admin and orders
const ADMIN_PASS = "0779418419";
let clickCount = 0, clickTimer = null;

document.getElementById('secretBtn').onclick = () => {
    clickCount++;
    clearTimeout(clickTimer);
    if (clickCount >= 5) {
        document.getElementById('adminPanel').style.display = 'block';
        document.getElementById('overlay').style.display = 'block';
        clickCount = 0;
    }
    clickTimer = setTimeout(() => clickCount = 0, 3000);
};

document.getElementById('whatsappFloat').onclick = () => window.open('https://wa.me/0779418419', '_blank');

function getOrders() { return JSON.parse(localStorage.getItem('abdo_orders_v4') || '[]'); }
function saveOrders(orders) { localStorage.setItem('abdo_orders_v4', JSON.stringify(orders)); }

function sendOrder() {
    let name = document.getElementById('userName').value.trim();
    let phone = document.getElementById('userPhone').value.trim();
    let service = document.getElementById('serviceSelect').value;
    let msg = document.getElementById('orderMsg').value.trim();
    if (!name || !phone) { alert('❌ الرجاء إدخال الاسم ورقم الجوال'); return; }
    if (!service) { alert('❌ الرجاء اختيار الخدمة'); return; }
    let orders = getOrders();
    orders.push({ id: Date.now(), name, phone, service, msg: msg || 'لا توجد تفاصيل', date: new Date().toLocaleString('ar-EG') });
    saveOrders(orders);
    let toast = document.getElementById('toast');
    toast.style.display = 'block';
    setTimeout(() => toast.style.display = 'none', 3000);
    document.getElementById('userName').value = '';
    document.getElementById('userPhone').value = '';
    document.getElementById('serviceSelect').value = '';
    document.getElementById('orderMsg').value = '';
}

function checkLogin() {
    if (document.getElementById('adminPass').value === ADMIN_PASS) {
        document.getElementById('loginBox').style.display = 'none';
        document.getElementById('adminContent').style.display = 'block';
        showOrders();
    } else alert('⚠️ كلمة المرور غير صحيحة');
}

function showOrders() {
    let orders = getOrders();
    let container = document.getElementById('ordersContainer');
    if (!orders.length) { container.innerHTML = '<div style="text-align:center;padding:20px;">✨ لا توجد طلبات بعد ✨</div>'; return; }
    container.innerHTML = '';
    [...orders].reverse().forEach(o => {
        container.innerHTML += `<div class="order-item"><strong>${o.name}</strong> 📞 ${o.phone}<br>🎯 ${o.service}<br>📝 ${o.msg}<div style="margin-top:12px;display:flex;gap:10px;"><button onclick="copyOrder(${o.id})" style="background:rgba(255,255,255,0.1);border:none;padding:6px 14px;border-radius:30px;color:white;">نسخ</button><button onclick="deleteOrder(${o.id})" style="background:rgba(255,255,255,0.1);border:none;padding:6px 14px;border-radius:30px;color:white;">حذف</button></div><small>${o.date}</small></div>`;
    });
}

function copyOrder(id) {
    let order = getOrders().find(o => o.id === id);
    if (order) { navigator.clipboard.writeText(`الاسم: ${order.name}\nالجوال: ${order.phone}\nالخدمة: ${order.service}\nالتفاصيل: ${order.msg}`); alert('✅ تم النسخ'); }
}
function deleteOrder(id) {
    if (confirm('⚠️ حذف الطلب؟')) { saveOrders(getOrders().filter(o => o.id !== id)); showOrders(); alert('تم الحذف'); }
}
function closeAdmin() {
    document.getElementById('adminPanel').style.display = 'none';
    document.getElementById('overlay').style.display = 'none';
    document.getElementById('loginBox').style.display = 'block';
    document.getElementById('adminContent').style.display = 'none';
}
</script>
</body>
</html>
